# ══════════════════════════════════════════════════════════════
# .gitignore
# Archivos que Git NO debe rastrear ni subir al repositorio.
# ══════════════════════════════════════════════════════════════

# ── Credenciales y secretos ───────────────────────────────────
.env
*.tfvars.local
terraform.tfstate
terraform.tfstate.backup
*.tfstate*
crash.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# ── Terraform ─────────────────────────────────────────────────
.terraform/
.terraform.lock.hcl
*.tfplan
lambda_ingestion.zip
lambda_layer.zip
pandas_layer.zip

# ── Python ────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
.venv/
env/
ENV/
*.egg-info/
dist/
build/
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
.ruff_cache/

# ── VS Code ───────────────────────────────────────────────────
.vscode/settings.json
.vscode/launch.json
.vscode/*.log

# ── Sistema operativo ─────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.swo

# ── Resultados de Athena descargados localmente ───────────────
resultado_q*.csv
athena_results/

# ── Logs ──────────────────────────────────────────────────────
*.log
logs/
