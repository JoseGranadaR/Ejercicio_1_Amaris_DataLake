# ══════════════════════════════════════════════════════════════
# .env.example
# Plantilla de variables de entorno para desarrollo local.
#
# INSTRUCCIONES:
#   1. Copie este archivo: cp .env.example .env
#   2. Rellene los valores en .env con sus datos reales
#   3. NUNCA suba .env a Git — está en .gitignore
#
# Estas variables las usa scripts/athena_queries.py y los
# scripts de despliegue cuando se ejecutan desde su computador.
# En AWS (Lambda, Glue) las variables las inyecta Terraform.
# ══════════════════════════════════════════════════════════════

# ── Configuración AWS ─────────────────────────────────────────
# Región donde está desplegada la infraestructura
AWS_REGION=us-east-1

# Perfil de AWS CLI a usar (si tiene múltiples cuentas)
# Dejar vacío para usar las credenciales por defecto
AWS_PROFILE=

# ── Nombres de recursos (se generan automáticamente con Terraform) ──
# Después de ejecutar terraform apply, copie los valores de los outputs aquí

# Nombre del bucket Landing (donde llegan los CSVs)
LANDING_BUCKET=amaris-dev-landing

# Nombre del bucket Processed (donde quedan los Parquet)
PROCESSED_BUCKET=amaris-dev-processed

# Nombre del job ETL de Glue
GLUE_JOB_NAME=amaris-dev-etl-energia-transform

# Nombre de la base de datos en el catálogo de Glue
GLUE_DATABASE=amaris_datalake_dev_processed

# Nombre del workgroup de Athena
ATHENA_WORKGROUP=amaris-dev

# Nombre del bucket de resultados de Athena
ATHENA_RESULTS_BUCKET=amaris-dev-athena-results

# ── Entorno ───────────────────────────────────────────────────
# Debe coincidir con el valor en terraform.tfvars
ENVIRONMENT=dev

# Fecha de partición para subir datos de prueba (YYYY-MM-DD)
PARTITION_DATE=2024-01-15
